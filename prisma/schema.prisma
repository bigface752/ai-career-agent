// AI Career Agent - Prisma Schema
// Database: Turso (SQLite/libsql)
// 所有主键使用 TEXT (cuid)，JSON 字段存储为 TEXT

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// 用户与认证
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  emailVerified Boolean   @default(false) @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastActiveAt  DateTime? @map("last_active_at")
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")

  // Relations
  portrait            Portrait?
  dialogueSessions    DialogueSession[]
  interviewSessions   InterviewSession[]
  reports             Report[]
  evaluations         Evaluation[]
  portraitCorrections PortraitCorrection[]
  portraitUpdateLogs  PortraitUpdateLog[]
  pendingUpdates      PendingUpdate[]
  emailVerifications  EmailVerification[]
  deviceSessions      DeviceSession[]
  notifications       Notification[]
  salarySubmissions   SalarySubmission[]
  jobDescriptions     JobDescription[]
  matchResults        MatchResult[]
  inviteCodeUsages    InviteCodeUsage[]

  @@map("users")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  code      String
  type      String
  expiresAt DateTime? @map("expires_at")
  used      Boolean   @default(false)
  attempts  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("email_verifications")
}

model DeviceSession {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  deviceInfo   String?   @map("device_info")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastActiveAt DateTime? @map("last_active_at")

  user User @relation(fields: [userId], references: [id])

  @@map("device_sessions")
}

// ============================================================
// 职业画像
// ============================================================

model Portrait {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  portraitJson String   @map("portrait_json") // JSON: 完整职业画像
  templateJson String?  @map("template_json") // JSON: 动态模板
  completion   Float    @default(0) // 0.0 ~ 1.0
  updatedAt    DateTime @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("portraits")
}

model PortraitCorrection {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  field     String // 字段路径
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  reason    String?
  status    String   @default("pending") // pending / accepted / rejected
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("portrait_corrections")
}

model PortraitUpdateLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  sessionId String?  @map("session_id")
  trigger   String // neat-freak / session_expiry / user_edit
  changes   String // JSON: 变更内容
  createdAt DateTime @default(now()) @map("created_at")

  user    User             @relation(fields: [userId], references: [id])
  session DialogueSession? @relation(fields: [sessionId], references: [id])

  @@map("portrait_update_logs")
}

model PendingUpdate {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  field         String // 冲突字段路径
  currentValue  String?   @map("current_value")
  proposedValue String?   @map("proposed_value")
  source        String // neat_freak / session_expiry
  sessionId     String?   @map("session_id")
  status        String    @default("pending") // pending / accepted / rejected / merged
  resolvedAt    DateTime? @map("resolved_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("pending_updates")
}

// ============================================================
// 对话系统
// ============================================================

model DialogueSession {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  module          String // career / match / interview
  status          String    @default("active") // active / paused / expired / archived
  slotState       String?   @map("slot_state") // JSON: Slot 填充状态
  recentWindow    String?   @map("recent_window") // JSON: 最近 3 轮原文
  initialFindings String?   @map("initial_findings") // JSON: 累积洞察
  roundNumber     Int       @default(0) @map("round_number")
  contextJson     String?   @map("context_json")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")
  expiresAt       DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id])

  dialogueMessages      DialogueMessage[]
  roundtableDiscussions RoundtableDiscussion[]
  reports               Report[]
  evaluations           Evaluation[]
  portraitUpdateLogs    PortraitUpdateLog[]

  @@map("dialogue_sessions")
}

model DialogueMessage {
  id            String   @id @default(cuid())
  sessionId     String   @map("session_id")
  role          String // user / assistant / agent
  agentId       String?  @map("agent_id")
  content       String
  extractedInfo String?  @map("extracted_info") // JSON: 结构化提取信息
  createdAt     DateTime @default(now()) @map("created_at")

  session DialogueSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
  @@map("dialogue_messages")
}

// ============================================================
// 圆桌讨论
// ============================================================

model RoundtableDiscussion {
  id             String   @id @default(cuid())
  sessionId      String   @map("session_id")
  module         String
  participants   String // JSON: 参与角色和模型
  rounds         String // JSON: 逐轮讨论内容
  consensus      String? // JSON: 共识结论
  disagreements  String? // JSON: 分歧点
  riskWarning    String?  @map("risk_warning") // JSON: 心理学家独立评价
  recommendation String?
  riskRating     String?  @map("risk_rating")
  conclusion     String?
  createdAt      DateTime @default(now()) @map("created_at")

  session DialogueSession @relation(fields: [sessionId], references: [id])

  @@map("roundtable_discussions")
}

// ============================================================
// 报告与反馈
// ============================================================

model Report {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  sessionId         String?   @map("session_id")
  module            String
  reportType        String    @map("report_type")
  content           String // HTML/JSON
  satisfactionScore Int?      @map("satisfaction_score") // 1-5
  feedbackText      String?   @map("feedback_text")
  shareToken        String?   @unique @map("share_token") // 分享 token
  sharedAt          DateTime? @map("shared_at") // 分享时间
  createdAt         DateTime  @default(now()) @map("created_at")

  user    User             @relation(fields: [userId], references: [id])
  session DialogueSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, createdAt])
  @@map("reports")
}

// ============================================================
// 竞争力评估
// ============================================================

model Evaluation {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  sessionId     String   @map("session_id")
  resultJson    String   @map("result_json") // JSON: EvaluationResult
  overallRating String   @map("overall_rating") // 强/中/弱
  overallScore  Float    @map("overall_score")
  createdAt     DateTime @default(now()) @map("created_at")

  user    User            @relation(fields: [userId], references: [id])
  session DialogueSession @relation(fields: [sessionId], references: [id])

  @@index([userId, sessionId, createdAt])
  @@map("evaluations")
}

// ============================================================
// Agent 配置
// ============================================================

model AgentRole {
  id                   String   @id @default(cuid())
  name                 String
  type                 String
  module               String?
  systemPrompt         String   @map("system_prompt")
  analysisDimensions   String?  @map("analysis_dimensions") // JSON: BARS 维度
  applicableIndustries String?  @map("applicable_industries") // JSON: 适用行业
  version              Int      @default(1)
  updatedAt            DateTime @default(now()) @map("updated_at")

  @@map("agent_roles")
}

// ============================================================
// 面试辅导
// ============================================================

model InterviewSession {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  jdId                 String?   @map("jd_id")
  round                String    @default("一面") // 一面 / 二面 / 终面 / HR面
  status               String    @default("not_started") // not_started / in_progress / paused / completed / abandoned / expired
  questions            String // JSON: [{id, type, question, focus}]
  currentQuestionIndex Int       @default(0) @map("current_question_index")
  answeredQuestions    String?   @map("answered_questions") // JSON: 每题的回答+评分
  conversationHistory  String?   @map("conversation_history") // JSON: 完整对话记录
  followUpCount        Int       @default(0) @map("follow_up_count") // 当前题追问次数
  evaluation           String? // JSON: L3 评估结果（BARS评分+逐题评估+优化答案）
  lastActivityAt       DateTime? @map("last_activity_at") // 最后活动时间（自动暂停用）
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @map("updated_at")
  expiresAt            DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("interview_sessions")
}

// ============================================================
// 通知系统
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // session_expiring / session_expired / session_cleaned
  title     String
  content   String
  sessionId String?  @map("session_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// 薪资数据
// ============================================================

model SalarySubmission {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  sessionId       String?  @map("session_id")
  annualSalary    Int      @map("annual_salary") // 年薪（元）
  monthlyBase     Int?     @map("monthly_base") // 月薪底薪（元）
  bonus           Int? // 年终奖/提成（元）
  position        String // data-analyst / b2b-sales / pmm
  city            String
  experienceYears Float?   @map("experience_years")
  companySize     String?  @map("company_size") // startup / scaleup / enterprise / unknown
  isBaseSalary    Boolean? @map("is_base_salary") // true=仅底薪
  source          String   @default("user_input") // user_input / imported
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, position, city])
  @@map("salary_submissions")
}

// ============================================================
// JD 解析（模块二）
// ============================================================

model JobDescription {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  positionName String   @map("position_name") // 解析出的岗位名
  companyType  String?  @map("company_type") // 公司类型
  confidence   String // high / low
  parsedJson   String   @map("parsed_json") // JSON: 完整解析结果
  inputMethod  String   @map("input_method") // text / position_name
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("job_descriptions")
}

// ============================================================
// 匹配分析结果（模块二）
// ============================================================

model MatchResult {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  jdId           String   @map("jd_id")
  overallRating  String   @map("overall_rating") // 强/中/弱
  dimensionsJson String   @map("dimensions_json") // 4 维度匹配结果
  gapsJson       String   @map("gaps_json") // 差距列表
  strengthsJson  String   @map("strengths_json") // 优势列表
  resumeJson     String   @map("resume_optimization_json") // 简历优化建议
  tokenUsage     Int      @default(0) @map("token_usage")
  createdAt      DateTime @default(now()) @map("created_at")

  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roundtableDiscussion MatchRoundtableDiscussion?

  @@index([userId, createdAt])
  @@map("match_results")
}

model MatchRoundtableDiscussion {
  id             String   @id @default(cuid())
  matchResultId  String   @unique @map("match_result_id")
  participants   String // JSON: 3 角色最终立场
  rounds         String // JSON: 2 轮讨论内容
  consensus      String // JSON: 共识结论 string[]
  disagreements  String // JSON: 分歧点 string[]
  recommendation String // JSON: 投递建议
  riskLevel      String   @map("risk_level") // 低/中/高
  tokenUsage     Int      @default(0) @map("token_usage")
  createdAt      DateTime @default(now()) @map("created_at")

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Cascade)

  @@map("match_roundtable_discussions")
}

// ============================================================
// 邀请码（灰度发布控制）
// ============================================================

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  label     String?   // 备注（如 "Alpha测试-张三"）
  maxUses   Int       @default(1) @map("max_uses")
  useCount  Int       @default(0) @map("use_count")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  usages InviteCodeUsage[]

  @@map("invite_codes")
}

model InviteCodeUsage {
  id         String   @id @default(cuid())
  codeId     String   @map("code_id")
  userId     String   @map("user_id")
  usedAt     DateTime @default(now()) @map("used_at")

  code InviteCode @relation(fields: [codeId], references: [id])
  user User       @relation(fields: [userId], references: [id])

  @@unique([codeId, userId])
  @@map("invite_code_usages")
}

