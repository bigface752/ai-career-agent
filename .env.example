# 数据库
DATABASE_URL=file:./dev.db
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=<your-token>

# JWT（用 openssl rand -base64 32 生成）
JWT_SECRET=<generate-with-openssl-rand-base64-32>

# AI 模型 API Keys
MIMO_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
GLM_API_KEY=

# 邮件
RESEND_API_KEY=

# 环境
NODE_ENV=production
