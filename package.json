    "ai": "^7.0.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "14.2.35",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^20",
